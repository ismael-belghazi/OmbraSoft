# ======= SERVER =========
PORT=8080
GIN_MODE=debug

# ======= DATABASE =========
# En production (Render) : utiliser DATABASE_URL
# En local : utiliser DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME

DATABASE_URL=
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_dev_password_change
DB_NAME=ombrasoft
DB_SSLMODE=disable

# ======= REDIS =========
# Format: redis://[user]:[password]@host:port/db
# Upstash: redis://default:[password]@[host].upstash.io:6379
# Vide = Redis désactivé

REDIS_URL=

# ======= JWT =========
JWT_SECRET=votre_clé_secrète_très_longue_et_aléatoire_CHANGEZ_MOI

# ======= CORS =========
# Domaines acceptés (séparés par virgule)
ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ======= PGADMIN =========
PGADMIN_DEFAULT_EMAIL=admin@ombrasoft.dev
PGADMIN_DEFAULT_PASSWORD=admin123
