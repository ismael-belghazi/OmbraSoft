# ======= SERVER =========
PORT=8080
GIN_MODE=debug

# ======= DATABASE =========
# En production (Render) : utiliser DATABASE_URL obligatoirement
# En local (docker-compose) : utiliser DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME

DB_HOST=ombrasoft-db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_local_dev
DB_NAME=ombrasoft
DB_SSLMODE=disable

# ======= REDIS =========
# Format: redis://[user]:[password]@host:port/db
# Upstash: redis://default:[password]@[host].upstash.io:6379
# Local: redis://redis:6379

REDIS_URL=redis://redis:6379

# ======= JWT =========
JWT_SECRET=dev_secret_change_in_production_min_64_chars
JWT_EXPIRY=24

VITE_API_URL=http://localhost:8080
ALLOW_ORIGINS=http://localhost:5173

# Frontend
REACT_APP_API_URL="http://backend:8080"

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
# ======= CORS =========
# Domaines acceptés (séparés par virgule)
ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# ======= PGADMIN =========
PGADMIN_DEFAULT_EMAIL=admin@ombrasoft.dev
PGADMIN_DEFAULT_PASSWORD=admin123

# ======= Appeise Notification Service =========
# pas encore en place - à configurer plus tard pour les notifications push (Pushbullet, Telegram, Discord, etc.)
DISCORD_BOT_TOKEN=ton_token_de_bot_discord

PUSHBULLET_URL=pusbullet://TOKEN

TELEGRAM_URL=telegram://TOKEN
